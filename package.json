{
  "name": "loanz360",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "NEXT_TELEMETRY_DISABLED=1 next build",
    "build:local": "set NODE_ENV=production&& set NODE_OPTIONS=--max-old-space-size=8192&& next build",
    "build:turbo": "set NODE_ENV=production&& set NODE_OPTIONS=--max-old-space-size=8192&& next build --turbopack",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:unit": "vitest run __tests__/incentives/unit",
    "test:unit:watch": "vitest watch __tests__/incentives/unit",
    "test:unit:ui": "vitest --ui __tests__/incentives/unit",
    "test:integration": "vitest run __tests__/incentives/integration",
    "test:e2e": "playwright test __tests__/incentives/e2e",
    "test:e2e:headed": "playwright test __tests__/incentives/e2e --headed",
    "test:e2e:debug": "playwright test __tests__/incentives/e2e --debug",
    "test:load": "k6 run __tests__/incentives/load/k6-load-test.js",
    "test:load:smoke": "k6 run --env SCENARIO=smoke __tests__/incentives/load/k6-load-test.js",
    "test:load:stress": "k6 run --env SCENARIO=stress __tests__/incentives/load/k6-load-test.js",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:all:coverage": "npm run test:unit -- --coverage && npm run test:integration",
    "setup:users": "npx tsx scripts/create-all-users.ts",
    "setup:dummy-users": "npx tsx scripts/create-dummy-users.ts",
    "setup:superadmin": "npx tsx scripts/create-superadmin.ts",
    "security:audit": "npm audit --audit-level=high",
    "security:audit:fix": "npm audit fix",
    "security:audit:full": "npm audit --json > security-audit-report.json",
    "security:check": "npx tsx scripts/security-check.ts",
    "security:test": "vitest run __tests__/security",
    "security:scan": "npm run security:audit && npm run security:check",
    "preinstall": "npx npm-force-resolutions || true",
    "postinstall": "npm audit --audit-level=critical || true"
  },

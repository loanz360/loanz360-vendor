{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "export NODE_OPTIONS='--max-old-space-size=8192' && next build",
  "installCommand": "npm install --legacy-peer-deps --include=dev",
  "framework": "nextjs",
  "regions": [
    "bom1"
  ],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [],
  "ignoreCommand": "git log -1 --pretty=%B | grep -qF \"[deploy]\" && exit 1 || exit 0"
}
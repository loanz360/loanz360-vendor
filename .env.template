# LOANZ360 Environment Configuration Template
# ===========================================
# SECURITY: Never commit actual credentials to git
# Copy this file to .env.local and fill in your values

# Supabase Configuration
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Application Configuration
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-strong-random-secret-here

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LOANZ 360

# Super Admin Configuration
# Generate password hash: node -e "const bcrypt = require('bcrypt'); bcrypt.hash('your-password', 12, (e,h) => console.log(h))"
SUPER_ADMIN_EMAIL=superadmin@loanz360.com
SUPER_ADMIN_PASSWORD_HASH=generate-bcrypt-hash-here

# JWT Configuration
# Generate secrets: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=generate-random-base64-secret-here
SESSION_SECRET=generate-random-base64-secret-here
CSRF_SECRET=generate-random-base64-secret-here
JWT_REFRESH_SECRET=generate-random-base64-secret-here

# Encryption Configuration
# CRITICAL: This key encrypts PII/PCI data (Aadhaar, PAN, bank accounts)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# PRODUCTION: Use AWS KMS, Azure Key Vault, or HashiCorp Vault
ENCRYPTION_MASTER_KEY=generate-32-byte-base64-key-here

# Rate Limiting Configuration
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=900
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_REGISTER_WINDOW=3600

# Security Settings
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true

# Feature Flags
FEATURE_2FA_ENABLED=true
FEATURE_EMAIL_VERIFICATION_REQUIRED=true

# Monitoring & Error Tracking (Optional)
# SENTRY_DSN=your-sentry-dsn-here
# NEXT_PUBLIC_SENTRY_DSN=your-public-sentry-dsn-here

# Email Configuration (Optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@loanz360.com

# Production Environment Variables (Set in Vercel/AWS/Azure)
# DATABASE_URL=postgresql://user:pass@host:5432/db
# REDIS_URL=redis://user:pass@host:6379

# =================================================================
# GOOGLE reCAPTCHA v3 CONFIGURATION
# =================================================================
# Get your keys from: https://www.google.com/recaptcha/admin
# Register a new site and choose reCAPTCHA v3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-site-key-here
RECAPTCHA_SECRET_KEY=your-secret-key-here

# Development/Testing Keys (always return success - for testing only)
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
# RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe

# =================================================================
# EMAIL PROVIDER CONFIGURATION
# =================================================================
# Choose: resend, sendgrid, or smtp
EMAIL_PROVIDER=resend
EMAIL_API_KEY=your-email-api-key
EMAIL_FROM=noreply@loanz360.com
EMAIL_FROM_NAME=LOANZ 360

# =================================================================
# SMS PROVIDER CONFIGURATION
# =================================================================
# Choose: twilio, msg91, or custom
SMS_PROVIDER=custom
SMS_API_KEY=your-sms-api-key
SMS_API_URL=https://api.sms.com/send
SMS_SENDER_ID=LOANZ360

# =================================================================
# MONITORING & ALERTS CONFIGURATION (Optional)
# =================================================================
# Slack Webhook for Alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxxx

# Email Alert Recipients (comma-separated)
ALERT_EMAIL_RECIPIENTS=admin@loanz360.com

# SMS Alert Recipients (comma-separated)
ALERT_SMS_RECIPIENTS=+919876543210

# =================================================================
# FEATURE FLAGS FOR FORTUNE 500 FEATURES
# =================================================================
NEXT_PUBLIC_ENABLE_AUTO_ASSIGNMENT=true
NEXT_PUBLIC_ENABLE_WEBHOOKS=true
NEXT_PUBLIC_ENABLE_BULK_OPERATIONS=true
NEXT_PUBLIC_ENABLE_ADVANCED_FILTERS=true
NEXT_PUBLIC_ENABLE_CAPTCHA=true

!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment files - NEVER commit secrets!
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
*.env.local
*.env.backup
.env.backup
.env.bak

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE and OS
.vscode/
.idea/
*.swp
*.swo
Thumbs.db


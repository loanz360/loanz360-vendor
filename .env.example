# ============================================================================
# LOANZ 360 - Environment Configuration Template
# ============================================================================
# Copy this file to .env.local for development
# NEVER commit .env.local to version control
# ============================================================================

# ----------------------------------------------------------------------------
# APPLICATION SETTINGS
# ----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="LOANZ 360"

# ----------------------------------------------------------------------------
# SUPABASE CONFIGURATION
# ----------------------------------------------------------------------------
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database Connection (for direct access if needed)
SUPABASE_DB_HOST=db.your-project.supabase.co
SUPABASE_DB_PASSWORD=your-database-password

# ----------------------------------------------------------------------------
# AUTHENTICATION & SECURITY
# ----------------------------------------------------------------------------
# Generate strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-here

# Session Configuration
SESSION_SECRET=your-session-secret-key-here
SESSION_MAX_AGE=604800

# CSRF Token Secret
CSRF_SECRET=your-csrf-secret-key-here

# Cron Job Authentication Secret (for automated tasks)
# Generate: openssl rand -hex 32
CRON_SECRET=your-cron-secret-key-here

# ----------------------------------------------------------------------------
# ENCRYPTION AT REST (PCI-DSS, GDPR)
# ----------------------------------------------------------------------------
# CRITICAL: Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# This key encrypts PII/PCI data (PAN, Aadhar, SSN, Bank Accounts)
# PRODUCTION: Store in AWS KMS, Azure Key Vault, or HashiCorp Vault
ENCRYPTION_MASTER_KEY=your-256-bit-encryption-key-base64-encoded-here

# Key Rotation (rotate every 90 days for compliance)
ENCRYPTION_KEY_VERSION=1
ENCRYPTION_KEY_ROTATION_DATE=2025-01-01

# ----------------------------------------------------------------------------
# SUPER ADMIN CREDENTIALS
# ----------------------------------------------------------------------------
# DEPRECATED: Use database instead - these are only for initial setup
SUPER_ADMIN_EMAIL=admin@loanz360.com
SUPER_ADMIN_PASSWORD_HASH=$2a$12$placeholder-hash-here

# Emergency Password Reset Key (for super admins when email fails)
# Generate strong key: openssl rand -base64 32
SUPER_ADMIN_EMERGENCY_KEY=CHANGE_THIS_IN_PRODUCTION_123!

# Password Policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=false

# ----------------------------------------------------------------------------
# RATE LIMITING
# ----------------------------------------------------------------------------
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=900
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_REGISTER_WINDOW=3600
RATE_LIMIT_PASSWORD_RESET_MAX=3
RATE_LIMIT_PASSWORD_RESET_WINDOW=3600

# ----------------------------------------------------------------------------
# EMAIL CONFIGURATION
# ----------------------------------------------------------------------------
# Resend Email Service (Recommended - 100 emails/day free)
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@loanz360.com
RESEND_FROM_NAME="LOANZ 360"

# Legacy SMTP Settings (Alternative - not currently used)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@loanz360.com
SMTP_FROM_NAME="LOANZ 360"

# Email Templates
EMAIL_VERIFICATION_REDIRECT=/auth/verify
PASSWORD_RESET_REDIRECT=/reset-password

# ----------------------------------------------------------------------------
# CORS CONFIGURATION
# ----------------------------------------------------------------------------
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://loanz360.com,https://www.loanz360.com

# ----------------------------------------------------------------------------
# LOGGING & MONITORING
# ----------------------------------------------------------------------------
# Log Levels: error, warn, info, debug
LOG_LEVEL=info

# Sentry (Error Monitoring)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-org
SENTRY_PROJECT=loanz360

# ----------------------------------------------------------------------------
# FILE UPLOAD (Future Use)
# ----------------------------------------------------------------------------
# AWS S3 or Supabase Storage
STORAGE_PROVIDER=supabase
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=loanz360-documents

# Supabase Storage
SUPABASE_STORAGE_BUCKET=documents

# Contest Image Storage
NEXT_PUBLIC_CONTEST_IMAGES_BUCKET=contest-images

# Upload Limits
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=.pdf,.jpg,.jpeg,.png,.doc,.docx

# ----------------------------------------------------------------------------
# PAYMENT GATEWAY (Future Use)
# ----------------------------------------------------------------------------
# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Stripe
STRIPE_PUBLIC_KEY=pk_test_your-stripe-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ----------------------------------------------------------------------------
# SMS GATEWAY
# ----------------------------------------------------------------------------
# MSG91 (Recommended for India)
# Get credentials from: https://msg91.com
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=LOANZ
MSG91_ROUTE=4

# Twilio (International Option)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# SmartPing (India DLT Compliant) - RECOMMENDED
# Get credentials from: https://gui.smartping.ai/
SMARTPING_API_ENDPOINT=https://api.smartping.ai/fe/api/v1/send
SMARTPING_USERNAME=your-username
SMARTPING_PASSWORD=your-password
SMARTPING_DEFAULT_SENDER_ID=SENDERID
SMARTPING_DLT_PRINCIPAL_ENTITY_ID=your-dlt-entity-id

# ----------------------------------------------------------------------------
# AI/ML SERVICES
# ----------------------------------------------------------------------------
# Google Gemini API (for Knowledge Base Chatbot)
# Get API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ----------------------------------------------------------------------------
# ANALYTICS (Future Use)
# ----------------------------------------------------------------------------
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX

# ----------------------------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------------------------
FEATURE_2FA_ENABLED=true
FEATURE_EMAIL_VERIFICATION_REQUIRED=true
FEATURE_SMS_OTP_ENABLED=true
FEATURE_SOCIAL_LOGIN_ENABLED=false

# Contest Management Feature Flags
ENABLE_AUTO_ENROLLMENT=true
ENABLE_REAL_TIME_SCORING=true
ENABLE_IMAGE_UPLOADS=true
ENABLE_TIMEZONE_SUPPORT=true

# Default Timezone (for contest dates and times)
# Options: Asia/Kolkata, UTC, America/New_York, Europe/London, etc.
NEXT_PUBLIC_DEFAULT_TIMEZONE=Asia/Kolkata

# ----------------------------------------------------------------------------
# DEVELOPMENT TOOLS
# ----------------------------------------------------------------------------
# Show detailed error pages (disable in production)
SHOW_ERROR_DETAILS=true

# Enable debug logging
DEBUG=false

# Bypass certain security checks (NEVER in production)
BYPASS_RATE_LIMITING=false
BYPASS_CSRF_PROTECTION=false

# ----------------------------------------------------------------------------
# PRODUCTION SETTINGS (Override in production .env)
# ----------------------------------------------------------------------------
# NODE_ENV=production
# SHOW_ERROR_DETAILS=false
# DEBUG=false
# BYPASS_RATE_LIMITING=false
# BYPASS_CSRF_PROTECTION=false
# LOG_LEVEL=error

# ============================================================================
# PHASE 3: PERFORMANCE & TESTING
# ============================================================================

# ----------------------------------------------------------------------------
# REDIS CACHE CONFIGURATION (Optional - improves performance 10x)
# ----------------------------------------------------------------------------
# Get from: Upstash (upstash.com), AWS ElastiCache, or self-hosted
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password-here
REDIS_TLS_ENABLED=false

# Cache TTL Override (seconds) - Optional
CACHE_TTL_LEADERBOARD=300
CACHE_TTL_ANALYTICS=600
CACHE_TTL_PARTICIPANT=180

# ----------------------------------------------------------------------------
# PERFORMANCE MONITORING
# ----------------------------------------------------------------------------
ENABLE_PERFORMANCE_TRACKING=true
PERFORMANCE_ALERT_THRESHOLD_MS=1000
SLOW_QUERY_THRESHOLD_MS=500

# Metric Retention
METRIC_RETENTION_MS=3600000
MAX_METRICS_STORED=10000

# ============================================================================
# SECURITY REMINDERS
# ============================================================================
# 1. NEVER commit .env.local to version control
# 2. Use strong random secrets (minimum 32 characters)
# 3. Rotate secrets regularly (every 90 days)
# 4. Different secrets for dev/staging/production
# 5. Store production secrets in vault (AWS Secrets Manager, etc.)
# 6. Enable 2FA on all service accounts
# 7. Use environment-specific Supabase projects
# 8. Rotate encryption keys every 90 days (PCI-DSS requirement)
# ============================================================================

# ============================================================================
# FEATURE FLAGS
# ============================================================================
NEXT_PUBLIC_CREDIT_BUREAU_ENABLED=false   # Set to true when ULI Hub API keys are configured
